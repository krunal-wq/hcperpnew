{% extends "base.html" %}
{% block title %}{{ 'Edit' if employee else 'Add' }} Employee{% endblock %}
{% block page_title %}{{ 'Edit' if employee else 'Add' }} Employee{% endblock %}
{% block bread %}HR / Employees / {{ 'Edit' if employee else 'Add' }}{% endblock %}

{% block extra_css %}
/* ── Card headers & body ── */
.card-hdr-sm{
    padding:.75rem 1.1rem;
    border-bottom:1px solid var(--border);
    display:flex;align-items:center;justify-content:space-between;
    background:linear-gradient(135deg,#f8fafc 0%,#f1f5f9 100%);
    border-radius:12px 12px 0 0;
}
.card-hdr-sm .card-title{font-size:.82rem;font-weight:800;color:var(--text1);letter-spacing:.01em;}
.card-body-sm{padding:1.1rem 1.25rem;}

/* ── Section sub-header ── */
.sec-hdr{
    font-size:.75rem;font-weight:800;color:var(--text2);
    text-transform:uppercase;letter-spacing:.06em;
    margin:1rem 0 .6rem;padding-bottom:.35rem;
    border-bottom:2px solid #e2e8f0;
}

/* ── Photo zone ── */
.photo-zone{padding:1.25rem;display:flex;flex-direction:column;align-items:center;gap:.85rem;}
.photo-preview{
    width:115px;height:115px;border-radius:50%;
    border:3px solid var(--blue);background:#e2e8f0;
    display:flex;align-items:center;justify-content:center;
    font-size:2.5rem;overflow:hidden;flex-shrink:0;
    box-shadow:0 4px 14px rgba(37,99,235,.15);
}
.photo-preview img{width:100%;height:100%;object-fit:cover;border-radius:50%;}
.ph-btns{display:flex;gap:.4rem;flex-wrap:wrap;justify-content:center;}
.ph-btn{
    padding:5px 13px;border-radius:8px;font-size:.77rem;font-weight:700;
    cursor:pointer;border:1.5px solid;font-family:inherit;
    display:inline-flex;align-items:center;gap:4px;transition:opacity .15s;
}
.ph-btn:hover{opacity:.85;}
.ph-btn-cam  {background:#eff6ff;color:#1d4ed8;border-color:#bfdbfe;}
.ph-btn-file {background:#f0fdf4;color:#16a34a;border-color:#86efac;}
.ph-btn-clear{background:#fee2e2;color:#dc2626;border-color:#fecaca;}
.divider{width:100%;border:none;border-top:1px solid var(--border);margin:.25rem 0;}

/* ── QR box ── */
.qr-box{text-align:center;}
.qr-box img{
    width:115px;height:115px;
    border:2px solid var(--border);border-radius:10px;
    display:block;margin:0 auto;
    box-shadow:0 2px 8px rgba(0,0,0,.08);
}
.qr-lbl{font-size:.7rem;color:var(--text3);margin-top:5px;font-weight:700;letter-spacing:.03em;}
.qr-pending{
    width:115px;height:115px;border:2px dashed #cbd5e1;border-radius:10px;
    display:flex;align-items:center;justify-content:center;flex-direction:column;
    gap:5px;background:#f8fafc;font-size:.71rem;color:var(--text3);
    margin:0 auto;text-align:center;line-height:1.4;
}
.qr-status{font-size:.7rem;margin-top:5px;text-align:center;min-height:16px;}

/* ── Camera modal ── */
.camera-overlay{
    display:none;position:fixed;inset:0;background:rgba(0,0,0,.75);
    z-index:9999;align-items:center;justify-content:center;
}
.camera-overlay.show{display:flex;}
.camera-box{background:#000;border-radius:16px;overflow:hidden;width:400px;max-width:95vw;box-shadow:0 20px 60px rgba(0,0,0,.5);}
.camera-bar{background:#111;padding:.75rem 1rem;display:flex;justify-content:space-between;align-items:center;}
.camera-bar span{color:#fff;font-size:.85rem;font-weight:700;}
#camVideo{width:100%;display:block;}
.camera-btns{background:#111;padding:.75rem;display:flex;gap:.5rem;justify-content:center;}
.cbtn{padding:8px 22px;border-radius:8px;border:none;font-size:.83rem;font-weight:700;cursor:pointer;font-family:inherit;}
.cbtn-cap{background:#2563eb;color:#fff;}
.cbtn-cls{background:#374151;color:#fff;}

/* ── Form actions bar ── */
.form-actions{
    display:flex;align-items:center;gap:.75rem;
    padding:1rem 1.25rem;
    background:#fff;border-radius:12px;
    border:1px solid var(--border);
    box-shadow:0 2px 8px rgba(0,0,0,.05);
    margin-bottom:1.5rem;
}
{% endblock %}

{% block content %}
<div class="page-hdr">
    <div>
        <h1 style="font-size:1.2rem;">{{ '✏️ Edit Employee' if employee else '➕ Add Employee' }}</h1>
        {% if employee %}<p style="font-size:.78rem;color:var(--text3);">Code: <strong>{{ employee.employee_code or '—' }}</strong></p>{% endif %}
    </div>
    <a href="{{ url_for('hr.employees') }}" class="btn-outline" style="font-size:.82rem;">← Back</a>
</div>

<form method="POST" id="empForm">
<input type="hidden" name="photo_base64" id="photoBase64" value="{{ employee.profile_photo or '' }}">
<input type="hidden" name="qr_base64"   id="qrBase64"   value="{{ employee.qr_code_base64 or '' }}">

<!-- Row 1: Photo+QR | Basic Info -->
<div style="display:grid;grid-template-columns:210px 1fr;gap:1.25rem;margin-bottom:1.25rem;">

    <!-- Photo + QR -->
    <div class="card">
        <div class="card-hdr-sm"><span class="card-title">📸 Photo & QR</span></div>
        <div class="photo-zone">
            <!-- Photo Preview -->
            <div class="photo-preview" id="previewWrap">
                {% if employee and employee.profile_photo %}
                <img id="previewImg" src="{{ employee.profile_photo }}" alt="Photo">
                {% else %}
                <span id="previewEmoji" style="font-size:2.5rem;">👤</span>
                {% endif %}
            </div>
            <!-- Photo Buttons -->
            <div class="ph-btns">
                <button type="button" class="ph-btn ph-btn-cam" onclick="openCamera()">📷 Camera</button>
                <label class="ph-btn ph-btn-file">
                    🗂️ Browse
                    <input type="file" id="photoFile" accept="image/*" style="display:none;" onchange="loadFile(this)">
                </label>
                <button type="button" class="ph-btn ph-btn-clear" id="clearPhotoBtn"
                    onclick="clearPhoto()"
                    style="display:{{ 'inline-flex' if employee and employee.profile_photo else 'none' }};">✕ Clear</button>
            </div>
            <hr class="divider">
            <!-- QR Display -->
            <div id="qrDisplay">
                {% if employee and employee.qr_code_base64 %}
                <div class="qr-box">
                    <img src="{{ employee.qr_code_base64 }}" id="qrImg" alt="QR">
                    <div class="qr-lbl">{{ employee.employee_code }}</div>
                </div>
                {% else %}
                <div class="qr-pending" id="qrPending">
                    <span style="font-size:1.6rem;">🔲</span>
                    <span>Enter employee<br>code to generate QR</span>
                </div>
                {% endif %}
            </div>
            <div id="qrStatus" class="qr-status"></div>
        </div>
    </div>

    <!-- Basic Info -->
    <div class="card">
        <div class="card-hdr-sm"><span class="card-title">👤 Basic Information</span></div>
        <div class="card-body-sm">
            <div class="fgrid-3" style="margin-bottom:.85rem;">
                <div class="fg">
                    <label class="fl">Employee Code *</label>
                    {% if employee and employee.employee_code %}
                        <input type="text" name="employee_code" id="empCodeInput" class="fi"
                            value="{{ employee.employee_code }}" readonly
                            style="background:#f8fafc;color:var(--text2);font-weight:700;">
                    {% else %}
                        <input type="text" name="employee_code" id="empCodeInput" class="fi"
                            value="{{ employee.employee_code if employee else '' }}"
                            placeholder="e.g. EMP1001" required>
                        <span style="font-size:.7rem;color:var(--text3);margin-top:2px;display:block;">QR auto-generates on input</span>
                    {% endif %}
                </div>
                <div class="fg">
                    <label class="fl">Employee Type *</label>
                    <select name="employee_type" class="fi sd">
                        <option value="">Select</option>
                        {% for t in ['Full Time','Part Time','Contract','Intern','Consultant'] %}
                        <option value="{{ t }}" {{ 'selected' if employee and employee.employee_type==t }}>{{ t }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="fg">
                    <label class="fl">Is Contractor?</label>
                    <select name="is_contractor" class="fi" id="isContractorSel" onchange="toggleContractor(this.value)">
                        <option value="no"  {{ 'selected' if not employee or not employee.is_contractor }}>No</option>
                        <option value="yes" {{ 'selected' if employee and employee.is_contractor }}>Yes</option>
                    </select>
                </div>
            </div>
            <div class="frow" id="contractorRow" style="display:none;margin-bottom:.7rem;">
                <label class="fl">Select Contractor</label>
                <select name="contractor_id" class="fi sd" id="contractorSel">
                    <option value="">— Select Contractor —</option>
                    {% for c in contractors %}
                    <option value="{{ c.id }}" {{ 'selected' if employee and employee.contractor_id==c.id }}>
                        {{ c.contract_id }} — {{ c.company_name }}
                    </option>
                    {% endfor %}
                </select>
            </div>
            <div class="fgrid-2">
                <div class="fg">
                    <label class="fl">First Name *</label>
                    <input type="text" name="first_name" class="fi" required
                        value="{{ employee.first_name if employee else '' }}" placeholder="First name">
                </div>
                <div class="fg">
                    <label class="fl">Last Name *</label>
                    <input type="text" name="last_name" class="fi" required
                        value="{{ employee.last_name if employee else '' }}" placeholder="Last name">
                </div>
                <div class="fg">
                    <label class="fl">Mobile *</label>
                    <input type="text" name="mobile" class="fi" required
                        value="{{ employee.mobile if employee else '' }}" placeholder="9999999999">
                </div>
                <div class="fg">
                    <label class="fl">Email Address</label>
                    <input type="email" name="email" class="fi"
                        value="{{ employee.email if employee else '' }}" placeholder="email@company.com">
                </div>
                <div class="fg" style="grid-column:1/-1;">
                    <label class="fl">Gender</label>
                    <select name="gender" class="fi sd" style="max-width:280px;">
                        <option value="">Select Gender</option>
                        {% for g in ['Male','Female','Other'] %}
                        <option value="{{ g }}" {{ 'selected' if employee and employee.gender==g }}>{{ g }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Row 2: Professional + Personal -->
<div class="form-panels" style="margin-bottom:1.25rem;">
    <div class="card">
        <div class="card-hdr-sm"><span class="card-title">🏢 Professional Details</span></div>
        <div class="card-body-sm">
            <div class="fgrid-2" style="margin-bottom:.85rem;">
                <div class="fg">
                    <label class="fl">Department</label>
                    <input type="text" name="department" class="fi" list="deptList"
                        value="{{ employee.department if employee else '' }}" placeholder="e.g. Sales, HR, IT">
                    <datalist id="deptList">
                        {% for d in ['Sales','HR','IT','Finance','Operations','Marketing','Production','Quality','Admin'] %}
                        <option value="{{ d }}">{% endfor %}
                    </datalist>
                </div>
                <div class="fg">
                    <label class="fl">Designation</label>
                    <input type="text" name="designation" class="fi"
                        value="{{ employee.designation if employee else '' }}" placeholder="e.g. Manager">
                </div>
                <div class="fg">
                    <label class="fl">Reports To (Manager)</label>
                    <select name="reports_to" class="fi sd">
                        <option value="">— No Manager (Top Level) —</option>
                        {% for e in all_employees %}
                        {% if not employee or e.id != employee.id %}
                        <option value="{{ e.id }}" {{ 'selected' if employee and employee.reports_to == e.id }}>
                            {{ e.employee_code }} — {{ e.full_name }}{% if e.designation %} ({{ e.designation }}){% endif %}
                        </option>
                        {% endif %}
                        {% endfor %}
                    </select>
                </div>
                <div class="fg">
                    <label class="fl">Date of Joining</label>
                    <input type="date" name="date_of_joining" class="fi"
                        value="{{ employee.date_of_joining.strftime('%Y-%m-%d') if employee and employee.date_of_joining else '' }}">
                </div>
                <div class="fg">
                    <label class="fl">Location</label>
                    <select name="location" class="fi sd">
                        <option value="">Select</option>
                        {% for l in ['Head Office','Branch Office','Site A','Site B','Remote','Warehouse'] %}
                        <option value="{{ l }}" {{ 'selected' if employee and employee.location==l }}>{{ l }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>
            <div class="sec-hdr">Social Profiles</div>
            <div class="fgrid-2">
                <div class="fg">
                    <label class="fl">LinkedIn</label>
                    <input type="text" name="linkedin" class="fi"
                        value="{{ employee.linkedin if employee else '' }}" placeholder="linkedin.com/in/...">
                </div>
                <div class="fg">
                    <label class="fl">Facebook</label>
                    <input type="text" name="facebook" class="fi"
                        value="{{ employee.facebook if employee else '' }}" placeholder="facebook.com/...">
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-hdr-sm"><span class="card-title">🪪 Personal Details</span></div>
        <div class="card-body-sm">
            <div class="fgrid-2" style="margin-bottom:.85rem;">
                <div class="fg">
                    <label class="fl">Date of Birth</label>
                    <input type="date" name="date_of_birth" class="fi"
                        value="{{ employee.date_of_birth.strftime('%Y-%m-%d') if employee and employee.date_of_birth else '' }}">
                </div>
                <div class="fg">
                    <label class="fl">Marital Status</label>
                    <select name="marital_status" class="fi sd">
                        {% for m in ['Single','Married','Divorced','Widowed'] %}
                        <option value="{{ m }}" {{ 'selected' if employee and employee.marital_status==m else ('selected' if not employee and m=='Single' else '') }}>{{ m }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="fg">
                    <label class="fl">Blood Group</label>
                    <select name="blood_group" class="fi sd">
                        <option value="">Select</option>
                        {% for bg in ['A+','A-','B+','B-','AB+','AB-','O+','O-'] %}
                        <option value="{{ bg }}" {{ 'selected' if employee and employee.blood_group==bg }}>{{ bg }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="fg">
                    <label class="fl">Status *</label>
                    <select name="status" class="fi sd">
                        <option value="active"     {{ 'selected' if not employee or employee.status=='active' }}>✅ Active</option>
                        <option value="inactive"   {{ 'selected' if employee and employee.status=='inactive' }}>⛔ Inactive</option>
                        <option value="terminated" {{ 'selected' if employee and employee.status=='terminated' }}>🔴 Terminated</option>
                        <option value="on_leave"   {{ 'selected' if employee and employee.status=='on_leave' }}>🟡 On Leave</option>
                    </select>
                </div>
            </div>
            <div class="sec-hdr">Flags</div>
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:.5rem;margin-bottom:.75rem;">
                <div class="fg">
                    <label class="fl">Is Block?</label>
                    <select name="is_block" class="fi">
                        <option value="no"  {{ 'selected' if not employee or not employee.is_block }}>No</option>
                        <option value="yes" {{ 'selected' if employee and employee.is_block }}>Yes</option>
                    </select>
                </div>
                <div class="fg">
                    <label class="fl">Is Late?</label>
                    <select name="is_late" class="fi">
                        <option value="no"  {{ 'selected' if not employee or not employee.is_late }}>No</option>
                        <option value="yes" {{ 'selected' if employee and employee.is_late }}>Yes</option>
                    </select>
                </div>
                <div class="fg">
                    <label class="fl">Is Probation?</label>
                    <select name="is_probation" class="fi">
                        <option value="no"  {{ 'selected' if employee and not employee.is_probation }}>No</option>
                        <option value="yes" {{ 'selected' if not employee or employee.is_probation }}>Yes</option>
                    </select>
                </div>
            </div>
            <div class="frow">
                <label class="fl">Remark</label>
                <textarea name="remark" class="fi" rows="3" placeholder="Additional notes...">{{ employee.remark if employee else '' }}</textarea>
            </div>
            {% if not employee %}
            <div style="margin-top:.75rem;">
                <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:.83rem;font-weight:600;">
                    <input type="checkbox" name="create_user" value="yes" style="accent-color:var(--blue);width:15px;height:15px;" checked>
                    Also create system login (password: HCP@123)
                </label>
            </div>
            {% endif %}
        </div>
    </div>
</div>

<div class="form-actions">
    <button type="submit" class="btn-primary" style="padding:10px 28px;font-size:.88rem;">
        {{ '💾 Update Employee' if employee else '✅ Save Employee' }}
    </button>
    <a href="{{ url_for('hr.employees') }}" class="btn-outline" style="padding:10px 20px;font-size:.88rem;">← Cancel</a>
</div>
</form>

<!-- Camera Modal -->
<div class="camera-overlay" id="cameraModal">
    <div class="camera-box">
        <div class="camera-bar">
            <span>📷 Capture Photo</span>
            <button type="button" onclick="closeCamera()" style="background:none;border:none;color:#94a3b8;font-size:1.2rem;cursor:pointer;">✕</button>
        </div>
        <video id="camVideo" autoplay playsinline></video>
        <canvas id="camCanvas" style="display:none;"></canvas>
        <div class="camera-btns">
            <button type="button" class="cbtn cbtn-cap" onclick="capturePhoto()">📸 Capture</button>
            <button type="button" class="cbtn cbtn-cls" onclick="closeCamera()">✕ Close</button>
        </div>
    </div>
</div>

<!-- Hidden div for qrcode.js rendering -->
<div id="qrRenderTarget" style="position:absolute;left:-9999px;top:-9999px;width:200px;height:200px;"></div>
{% endblock %}

{% block extra_js %}
// Load qrcode.js dynamically then init
(function loadQRLib() {
    var s = document.createElement('script');
    s.src = 'https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js';
    s.onload = function() { initQR(); };
    s.onerror = function() {
        // fallback: try another CDN
        var s2 = document.createElement('script');
        s2.src = 'https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js';
        s2.onload = function() { initQR(); };
        document.head.appendChild(s2);
    };
    document.head.appendChild(s);
})();

var qrObj      = null;
var qrReady    = false;
var qrPending  = null;   // code waiting to be rendered

function initQR() {
    qrReady = true;
    // If there was a code waiting, generate now
    if (qrPending) {
        _doGenerate(qrPending);
        qrPending = null;
    } else {
        // Edit page: employee has code but no QR saved
        {% if employee and employee.employee_code and not employee.qr_code_base64 %}
        _doGenerate('{{ employee.employee_code | e }}');
        {% endif %}
    }
}

function generateQR(code) {
    if (!code || !code.trim()) return;
    code = code.trim();
    if (!qrReady) {
        qrPending = code;   // library not loaded yet, store and wait
        return;
    }
    _doGenerate(code);
}

function _doGenerate(code) {
    var statusEl = document.getElementById('qrStatus');
    statusEl.innerHTML = '<span style="color:#64748b;">⏳ Generating QR...</span>';

    var target = document.getElementById('qrRenderTarget');
    target.innerHTML = '';

    try {
        qrObj = new QRCode(target, {
            text:         code,
            width:        200,
            height:       200,
            colorDark:    '#000000',
            colorLight:   '#ffffff',
            correctLevel: QRCode.CorrectLevel.M
        });
    } catch(e) {
        statusEl.innerHTML = '<span style="color:red;">❌ QR error: ' + e.message + '</span>';
        return;
    }

    // QRCode.js renders asynchronously — poll for canvas/img
    var attempts = 0;
    var poll = setInterval(function() {
        attempts++;
        var canvas = target.querySelector('canvas');
        var img    = target.querySelector('img');
        var dataUrl = null;

        if (canvas && canvas.width > 0) {
            dataUrl = canvas.toDataURL('image/png');
        } else if (img && img.src && img.src.indexOf('data:') === 0) {
            dataUrl = img.src;
        }

        if (dataUrl) {
            clearInterval(poll);
            document.getElementById('qrBase64').value = dataUrl;

            // Update display
            document.getElementById('qrDisplay').innerHTML =
                '<div class="qr-box">' +
                '<img src="' + dataUrl + '" style="width:110px;height:110px;border:2px solid #e2e8f0;border-radius:10px;">' +
                '<div class="qr-lbl">' + code + '</div>' +
                '</div>';

            statusEl.innerHTML = '<span style="color:#16a34a;">✅ QR ready</span>';
            setTimeout(function(){ statusEl.innerHTML=''; }, 2500);
        }

        if (attempts > 30) {
            clearInterval(poll);
            statusEl.innerHTML = '<span style="color:orange;">⚠️ QR generation slow</span>';
        }
    }, 100);
}

// Debounced input handler for employee code field
var codeTimer = null;
var codeInput = document.getElementById('empCodeInput');
if (codeInput && !codeInput.readOnly) {
    codeInput.addEventListener('input', function() {
        clearTimeout(codeTimer);
        var val = this.value.trim();
        codeTimer = setTimeout(function() {
            if (val.length >= 2) generateQR(val);
        }, 700);
    });
}

// ── Contractor toggle ──
function toggleContractor(val) {
    document.getElementById('contractorRow').style.display = val === 'yes' ? '' : 'none';
}
toggleContractor(document.getElementById('isContractorSel').value);

// ── Photo: file browse ──
function loadFile(input) {
    var file = input.files[0];
    if (!file) return;
    var reader = new FileReader();
    reader.onload = function(e) { compressAndSet(e.target.result); };
    reader.readAsDataURL(file);
}

function compressAndSet(dataUrl) {
    var img = new Image();
    img.onload = function() {
        var MAX = 400, canvas = document.createElement('canvas');
        var w = img.width, h = img.height;
        if (w > MAX) { h = Math.round(h * MAX / w); w = MAX; }
        if (h > MAX) { w = Math.round(w * MAX / h); h = MAX; }
        canvas.width = w; canvas.height = h;
        canvas.getContext('2d').drawImage(img, 0, 0, w, h);
        setPhoto(canvas.toDataURL('image/jpeg', 0.72));
    };
    img.src = dataUrl;
}

function setPhoto(dataUrl) {
    document.getElementById('photoBase64').value = dataUrl;
    var wrap = document.getElementById('previewWrap');
    var pi   = document.getElementById('previewImg');
    if (!pi) {
        wrap.innerHTML = '';
        pi = document.createElement('img');
        pi.id = 'previewImg';
        wrap.appendChild(pi);
    }
    pi.src = dataUrl;
    document.getElementById('clearPhotoBtn').style.display = 'inline-block';
    var em = document.getElementById('previewEmoji');
    if (em) em.style.display = 'none';
}

function clearPhoto() {
    document.getElementById('photoBase64').value = '';
    document.getElementById('previewWrap').innerHTML = '<span id="previewEmoji">👤</span>';
    document.getElementById('clearPhotoBtn').style.display = 'none';
}

// ── Camera ──
var camStream = null;
async function openCamera() {
    try {
        camStream = await navigator.mediaDevices.getUserMedia({video:{facingMode:'user'},audio:false});
        document.getElementById('camVideo').srcObject = camStream;
        document.getElementById('cameraModal').classList.add('show');
    } catch(e) { alert('Camera error: ' + e.message); }
}
function closeCamera() {
    if (camStream) { camStream.getTracks().forEach(function(t){t.stop();}); camStream = null; }
    document.getElementById('cameraModal').classList.remove('show');
}
function capturePhoto() {
    var video  = document.getElementById('camVideo');
    var canvas = document.getElementById('camCanvas');
    var MAX = 400, w = video.videoWidth, h = video.videoHeight;
    if (w > MAX) { h = Math.round(h*MAX/w); w = MAX; }
    canvas.width = w; canvas.height = h;
    canvas.getContext('2d').drawImage(video, 0, 0, w, h);
    setPhoto(canvas.toDataURL('image/jpeg', 0.72));
    closeCamera();
}
{% endblock %}
